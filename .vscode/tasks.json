{
    // Multiple patterns currently don't work, so make sure each task outputs only ONE type of message.
    "version":"2.0.0",
    "tasks": [
        {
            "label": "meta-checks",
            "args": [
                "${file}"
            ],
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "./checks/run_meta_check.py",
            "problemMatcher": {
                "severity": "info",
                "pattern": {
                    "regexp": "^::(notice|warning|error) file= ?(.*?),title=(.*?),col=([0-9]*),endColumn=([0-9]*),line=([0-9]*)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "code": 3,
                    "column": 4,
                    "endColumn": 5,
                    "line": 6,
                    "message": 7
                },
                "owner": "meta-check",
                "fileLocation": "autoDetect"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "proselint-checks",
            "args": [
                "${file}"
            ],
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "./checks/run_proselint.py",
            "problemMatcher": {
                "pattern": {
                    "regexp": "^::(notice|warning|error) file=(.*?),line=([0-9]*),col=([0-9]*),endColumn=([0-9]*),title=(.*?)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "endLine": 5,
                    "message": 7
                },
                "owner": "proselint",
                "fileLocation": "autoDetect"
            }
        },
        {
            "label": "spelling-checks",
            "args": [
                "${file}"
            ],
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "./checks/run_spell_check.py",
            "problemMatcher": {
                "pattern": {
                    "regexp": "^::(notice|warning|error) file=(.*?),line=([0-9]*),col=([0-9]*),endColumn=([0-9]*),title=(.*?)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "endColumn": 5,
                    "message": 7
                },
                "owner": "spelling",
                "fileLocation": "autoDetect"
            }
        },
        {
            "label": "test-build",
            "type": "shell",
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "export NO_MKDOCS_2_WARNING=1 && ./checks/run_test_build.py",
            "problemMatcher": {
                "severity": "info",
                "pattern": {
                    "regexp": "^::(.*) file=(.*?),title=(.*?),col=([0-9]*),endColumn=([0-9]*),line=([0-9]*)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "code": 3,
                    "column": 4,
                    "endColumn": 5,
                    "line": 6,
                    "message": 7
                },
                "owner": "test-build",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/docs"
                ]
            }
        },
        {
            "label": "slurm-lint",
            "args": [
                "${file}"
            ],
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "./checks/run_slurm_lint.py",
            "problemMatcher": {
                "severity": "info",
                "pattern": {
                    "regexp": "^::(notice|warning|error) file=(.*?),title=(.*?),col=([0-9]*),endColumn=([0-9]*),line=([0-9]*)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "code": 3,
                    "column": 4,
                    "endColumn": 5,
                    "line": 6,
                    "message": 7
                },
                "owner": "slurm-lint",
                "fileLocation": "autoDetect"
            }
        },
        {
            "label": "wcag-check",
            "args": [
                "${file}"
            ],
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "./checks/run_aria_check.py",
            "problemMatcher": {
                "severity": "info",
                "pattern": {
                    "regexp": "^::(notice|warning|error) file=(.*?),title=(.*?),col=([0-9]*),endColumn=([0-9]*),line=([0-9]*)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "code": 3,
                    "column": 4,
                    "endColumn": 5,
                    "line": 6,
                    "message": 7
                },
                "owner": "wcag-check",
                "fileLocation": "autoDetect"
            }
        },
        {
            "label": "fetch",
            "group": "none",
            "type": "shell",
            "isBackground": false,
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            },
            "command": "bash .github/fetch_includes.sh",
            "problemMatcher": {
                "severity": "info",
                "pattern": {
                    "regexp": "^::(notice|warning|error) file=(.*?),title=(.*?)::(.*)$",
                    "severity": 1,
                    "file": 2,
                    "code": 3,
                    "message": 4
                },
                "owner": "fetch",
                "fileLocation": "autoDetect"
            }
        },
        {
            "label": "serve",
            "group": "build",
            "type": "shell",
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "showReuseMessage": false
            },
            "command": "export NO_MKDOCS_2_WARNING=1 && mkdocs serve --dirty"
        },
        {
            "label": "a11y-audit",
            "detail": "Run the AccessLint WCAG audit against the locally built docs site",
            "group": "test",
            "type": "shell",
            "isBackground": false,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "dependsOn": "test-build",
            "command": "bash checks/run_a11y_check.sh"
        }
    ]
}
